<script>
// --- Custom cursor (desktop only) ---
const cur = document.getElementById('cur');
const fol = document.getElementById('fol');
if (cur && fol && window.matchMedia('(hover: hover) and (pointer: fine)').matches) {
  document.addEventListener('mousemove', e => {
    cur.style.left = e.clientX + 'px';
    cur.style.top  = e.clientY + 'px';
    fol.style.left = e.clientX + 'px';
    fol.style.top  = e.clientY + 'px';
  });
}

// --- Sticky nav ---
const nav = document.getElementById('nav');
window.addEventListener('scroll', () => {
  nav.classList.toggle('scrolled', window.scrollY > 40);
}, { passive: true });

// --- Scroll reveal ---
const revealEls = document.querySelectorAll('.reveal');
const observer = new IntersectionObserver(entries => {
  entries.forEach(e => {
    if (e.isIntersecting) {
      e.target.classList.add('visible');
      observer.unobserve(e.target);
    }
  });
}, { threshold: 0.12 });
revealEls.forEach(el => observer.observe(el));

// --- Project filter ---
function filter(type, btn) {
  document.querySelectorAll('.f-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  document.querySelectorAll('#pg .p-card').forEach(card => {
    const show = type === 'all' || card.dataset.t === type;
    card.style.display = show ? '' : 'none';
  });
}
</script>
